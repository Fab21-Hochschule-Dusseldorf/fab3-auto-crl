# Beispiel-Konfiguration fuer fb3-ca.sh
# Auf der OPNsense ablegen als:  /root/fb3-ca/fb3-ca.conf
# (wird beim Lauf automatisch geladen und ueberschreibt die Standardwerte)

# CRL-URL, die in JEDES neu signierte Zertifikat geschrieben wird (crlDistributionPoint).
# Bei GitHub-Hosting die raw-URL verwenden (HTTPS ist hier unkritisch):
CDP_URL="https://raw.githubusercontent.com/Fab21-Hochschule-Dusseldorf/fab3-auto-crl/main/fb3.crl"

# --- Veroeffentlichung der CRL via GitHub (Deploy-Key) ---
GIT_REPO_DIR="/root/fb3-ca/repo"                       # lokaler Klon des Repos
GIT_DEPLOY_KEY="/root/.ssh/fab3-auto-crl-deploy"       # privater Deploy-Key (NICHT im Repo)
GIT_BRANCH="main"

# --- Alternative: scp/lokal statt GitHub (dann GIT_REPO_DIR leer lassen) ---
#CRL_PUBLISH="user@webserver:/var/www/pki/fb3.crl"

DEFAULT_DAYS=1095      # Gueltigkeit ausgestellter Zertifikate (Tage)
CRL_DAYS=30           # Gueltigkeit der CRL (Tage) -> oefter als das erneuern!
